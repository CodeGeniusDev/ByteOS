{
  "name": "byteos-mac-assistant",
  "version": "0.1.0",
  "description": "ByteOS macOS AI assistant desktop app",
  "author": "Abdullah Abad",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "BYTEOS_NEXT_DEV=1 electron .",
    "next:dev": "cd ui && next dev -p 3020",
    "build:web": "cd ui && next build",
    "build": "npm run build:web",
    "icon": "python3 scripts/generate_app_icon.py",
    "pack": "npm run build:web && electron-builder --dir",
    "dist": "npm run build:web && electron-builder"
  },
  "build": {
    "appId": "com.byteos.macassistant",
    "productName": "ByteOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "ui/out/**/*",
      "config.json",
      "config.example.json",
      ".env.example",
      "README.md",
      "DESKTOP_APP_SETUP.md",
      "MAC_CONTROL_GUIDE.md",
      "STEP_BY_STEP_AI_ASSISTANT_GUIDE.md"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "clsx": "2.1.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "0.469.0",
    "next": "15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "electron": "42.5.0",
    "electron-builder": "26.15.3",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
